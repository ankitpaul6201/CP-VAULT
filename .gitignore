# ============================================================
# CP Vault — .gitignore
# ============================================================

# ────────────────────────────────────────────────
# SECURITY: Never commit secrets or credentials
# ────────────────────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
*.crt
*.cer
secrets/
credentials/
*credentials*
*secret*
*token*
*oauth*
*api_key*
*apikey*
*private*

# ────────────────────────────────────────────────
# Node.js
# ────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
.npm
.yarn-integrity
.pnpm-store
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions
jspm_packages/

# ────────────────────────────────────────────────
# Build Outputs
# ────────────────────────────────────────────────
dist/
build/
out/
.output/
.next/
.nuxt/

# ────────────────────────────────────────────────
# TypeScript
# ────────────────────────────────────────────────
*.tsbuildinfo

# ────────────────────────────────────────────────
# Vite / Parcel / Build Caches
# ────────────────────────────────────────────────
.vite/
.cache/
.parcel-cache/
vite.config.js.timestamp-*
vite.config.ts.timestamp-*

# ────────────────────────────────────────────────
# Coverage & Testing
# ────────────────────────────────────────────────
coverage/
*.lcov
.nyc_output/

# ────────────────────────────────────────────────
# Logs
# ────────────────────────────────────────────────
logs/
*.log
pids/
*.pid
*.seed
*.pid.lock

# ────────────────────────────────────────────────
# OS Generated Files
# ────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# ────────────────────────────────────────────────
# Editor / IDE
# ────────────────────────────────────────────────
.vscode/
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# ────────────────────────────────────────────────
# Miscellaneous
# ────────────────────────────────────────────────
*.tgz
*.zip
!CP-Vault-*.zip
lib-cov/
.grunt/
bower_components/
.lock-wscript
.tern-port
.vscode-test
.firebase/
.serverless/
.fusebox/
.dynamodb/
.svelte-kit/
.temp/
.docusaurus/
web_modules/
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# ────────────────────────────────────────────────
# Project Specific
# ────────────────────────────────────────────────
# Exclude any unrelated vendor/reference code
LeetHub-2.0-main/
